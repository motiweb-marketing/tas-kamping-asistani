# Proje KOK dizininde olmali (src/ icinde DEGIL)
# Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...   # anon public key (publishable degil)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Oturum imzalama (rastgele uzun bir string üretin)
SESSION_SECRET=degistirin-guclu-bir-gizli-anahtar

# OpenRouter: müşteri kendi anahtarını admin panelinden girer.
# Platform AI paketi için (sizin anahtarınız — satışta ayrı fiyatlandırın):
# PLATFORM_OPENROUTER_API_KEY=sk-or-...

# Platform sahibi paneli (/platform/login) — kamp organizatöründen AYRI
PLATFORM_ADMIN_USERNAME=
PLATFORM_ADMIN_PASSWORD=

# Site / SEO / satış iletişimi (opsiyonel)
NEXT_PUBLIC_SITE_URL=https://tas-kamping-hesaplayici.vercel.app
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_CONTACT_WHATSAPP=
